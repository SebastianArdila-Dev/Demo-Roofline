# =============================================================================
# Roofline Company — Variables de entorno
# =============================================================================
# Copia este archivo como .env y rellena los valores reales.
# El archivo .env NUNCA debe subirse a Git.
#
# Estas variables se usan SOLO en scripts locales (migrate-to-supabase.js).
# Para el frontend (catalogo.html, admin.html), edita directamente:
#   js/supabase-client.js  con SUPABASE_URL y SUPABASE_ANON_KEY
# =============================================================================

# URL de tu proyecto Supabase
# Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave pública anónima (puede ir en el frontend)
# Supabase Dashboard > Settings > API > anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio (NUNCA en el frontend, solo scripts locales)
# Supabase Dashboard > Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
